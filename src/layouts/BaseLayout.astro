---
import { site } from '../lib/site';

interface Props {
  title?: string;
  description?: string;
}

const { title = site.title, description = site.description } = Astro.props;
const canonical = new URL(Astro.url.pathname, site.url);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#f6f3ee" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={site.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header">
        <div class="site-intro">
          <a class="brand" href="/">{site.name}</a>
          <p class="site-subheading">
            Clarity is a system for building AI-native companies, created by Jamie Anson.
          </p>
        </div>
        <nav class="site-nav" aria-label="Primary">
          {
            site.nav.map((item) => (
              <a href={item.href} class={Astro.url.pathname === item.href ? 'active' : ''}>
                {item.label}
              </a>
            ))
          }
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <p>© Jamie Anson 2026. Clarity by Jamie Anson. Shared openly. Attribution required.</p>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
