---
import { site } from '../lib/site';
import {
  buildSiteStructuredData,
  stringifyStructuredData,
  toAbsoluteUrl
} from '../lib/metadata';

interface Props {
  title?: string;
  description?: string;
  hideHeader?: boolean;
  ogType?: 'website' | 'article';
  ogImage?: string;
  robots?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title = site.title,
  description = site.description,
  hideHeader = false,
  ogType = 'website',
  ogImage,
  robots = 'index, follow',
  structuredData
} = Astro.props;
const canonical = new URL(Astro.url.pathname, site.url);
const resolvedOgImage = toAbsoluteUrl(ogImage ?? site.defaultOgImage);
const structuredDataBlocks = [...buildSiteStructuredData(), ...(structuredData ? [structuredData] : [])];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#f6f3ee" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content="en_GB" />
    {resolvedOgImage && <meta property="og:image" content={resolvedOgImage} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {resolvedOgImage && <meta name="twitter:image" content={resolvedOgImage} />}
    <link rel="alternate" type="application/rss+xml" title={`${site.title} RSS Feed`} href="/rss.xml" />
    <link rel="alternate" type="application/rss+xml" title={`${site.title} Audio Feed`} href="/audio.xml" />
    <link rel="icon" href="/favicon-v2.svg" type="image/svg+xml" />
    <link rel="shortcut icon" href="/favicon-v2.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/favicon-v2.svg" />
    {
      structuredDataBlocks.map((item) => (
        <script is:inline type="application/ld+json" set:html={stringifyStructuredData(item)} />
      ))
    }
  </head>
  <body>
    <div class="page-shell">
      {
        !hideHeader && (
          <header class="site-header">
            <div class="site-intro">
              <a class="brand" href="/">{site.name}</a>
              <p class="site-subheading">
                Clarity is a system for building AI-native companies, created by Jamie Anson.
              </p>
              {
                site.nav.length > 0 && (
                  <nav class="site-nav" aria-label="Primary">
                    {
                      site.nav.map((item) => (
                        <a href={item.href} class={Astro.url.pathname === item.href ? 'active' : ''}>
                          {item.label}
                        </a>
                      ))
                    }
                  </nav>
                )
              }
            </div>
          </header>
        )
      }
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <p>© Jamie Anson 2026. Clarity by Jamie Anson. Shared openly. Attribution required.</p>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
