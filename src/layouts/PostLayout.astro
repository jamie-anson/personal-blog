---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  featured?: boolean;
  readingTime?: number;
  relatedPosts?: Array<{
    slug: string;
    data: {
      title: string;
      description: string;
    };
  }>;
  headings?: Array<{
    depth: number;
    slug: string;
    text: string;
  }>;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  featured = false,
  readingTime,
  relatedPosts = [],
  headings = []
} = Astro.props;
const tocHeadings = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
---

<BaseLayout title={`${title} | Essays`} description={description}>
  <div class="article-layout">
    {
      tocHeadings.length > 0 && (
        <aside class="article-toc" aria-label="On this page">
          <p class="toc-title">On this page</p>
          <nav class="toc-nav">
            {
              tocHeadings.map((heading) => (
                <a
                  href={`#${heading.slug}`}
                  class:list={[
                    'toc-link',
                    heading.depth === 3 && 'toc-link-nested'
                  ]}
                >
                  {heading.text}
                </a>
              ))
            }
          </nav>
          {
            relatedPosts.length > 0 && (
              <div class="toc-secondary">
                <p class="toc-title">Other pages</p>
                <nav class="toc-nav">
                  {
                    relatedPosts.map((post) => (
                      <a class="toc-link" href={`/posts/${post.slug}/`}>
                        {post.data.title}
                      </a>
                    ))
                  }
                </nav>
              </div>
            )
          }
        </aside>
      )
    }
    <article class="article-shell">
      <header class="article-header">
        <div class="article-title-block">
          <div class="article-meta">
            <time datetime={pubDate.toISOString()}>
              {pubDate.toLocaleDateString('en-GB', {
                day: 'numeric',
                month: 'long',
                year: 'numeric'
              })}
            </time>
            {readingTime && <span>{readingTime} min read</span>}
            {
              updatedDate && (
                <span>
                  Updated{' '}
                  {updatedDate.toLocaleDateString('en-GB', {
                    day: 'numeric',
                    month: 'long',
                    year: 'numeric'
                  })}
                </span>
              )
            }
          </div>
          <h1>{title}</h1>
          <p class="lede">{description}</p>
        </div>
        {
          featured && (
            <div class="article-summary">
              <p class="card-meta">In short</p>
              <p>
                Clarity is a system for replacing role-based coordination with explicit ownership of
                outcomes, so AI expands responsibility instead of flattening people into operators.
              </p>
            </div>
          )
        }
      </header>
      <div class="article-body">
        <slot />
      </div>
      {
        relatedPosts.length > 0 && (
          <footer class="article-footer">
            <div class="article-footer-heading">
              <p class="eyebrow">Further reading</p>
              <h2>Keep exploring the model</h2>
            </div>
            <div class="related-grid">
              {
                relatedPosts.map((post) => (
                  <a class="related-card" href={`/posts/${post.slug}/`}>
                    <p class="card-meta">Essay</p>
                    <h3>{post.data.title}</h3>
                    <p>{post.data.description}</p>
                  </a>
                ))
              }
            </div>
          </footer>
        )
      }
    </article>
  </div>
</BaseLayout>
