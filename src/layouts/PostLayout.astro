---
import BaseLayout from './BaseLayout.astro';
import { buildArticleStructuredData, toAbsoluteUrl } from '../lib/metadata';

interface Props {
  title: string;
  description: string;
  slug: string;
  audio?: {
    src: string;
    title?: string;
  };
  pubDate: Date;
  updatedDate?: Date;
  readingTime?: number;
  tags?: string[];
  keywords?: string[];
  category?: string;
  socialImage?: string;
  relatedPosts?: Array<{
    slug: string;
    data: {
      title: string;
      description: string;
    };
  }>;
  headings?: Array<{
    depth: number;
    slug: string;
    text: string;
  }>;
}

const {
  title,
  description,
  slug,
  audio,
  pubDate,
  updatedDate,
  readingTime,
  tags = [],
  keywords = [],
  category,
  socialImage,
  relatedPosts = [],
  headings = []
} = Astro.props;
const tocHeadings = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
const canonicalUrl = new URL(`/posts/${slug}/`, Astro.site ?? Astro.url).toString();
const resolvedSocialImage = toAbsoluteUrl(socialImage);
const articleStructuredData = buildArticleStructuredData({
  title,
  description,
  canonicalUrl,
  publishedTime: pubDate.toISOString(),
  modifiedTime: updatedDate?.toISOString(),
  image: resolvedSocialImage,
  tags,
  keywords,
  category
});
---

<BaseLayout
  title={`${title} | Essays`}
  description={description}
  ogType="article"
  ogImage={resolvedSocialImage}
  structuredData={articleStructuredData}
>
  <div class:list={['article-layout', tocHeadings.length === 0 && 'article-layout--no-toc']}>
    {
      tocHeadings.length > 0 && (
        <aside class="article-toc" aria-label="On this page" data-toc-root>
          <button
            class="toc-mobile-toggle"
            type="button"
            aria-expanded="false"
            aria-controls="article-toc-panel"
            data-toc-toggle
          >
            <span>On this page</span>
            <span class="toc-mobile-toggle-label">Menu</span>
          </button>
          <div class="toc-drawer-backdrop" hidden data-toc-backdrop></div>
          <div class="article-toc-panel" id="article-toc-panel" data-toc-panel>
            <div class="toc-panel-header">
              <p class="toc-title">On this page</p>
              <button class="toc-panel-close" type="button" aria-label="Close menu" data-toc-close>
                Close
              </button>
            </div>
            <nav class="toc-nav" data-toc-nav>
              {
                tocHeadings.map((heading) => (
                  <a
                    href={`#${heading.slug}`}
                    class:list={[
                      'toc-link',
                      heading.depth === 3 && 'toc-link-nested'
                    ]}
                  >
                    {heading.text}
                  </a>
                ))
              }
            </nav>
            {
              relatedPosts.length > 0 && (
                <div class="toc-secondary">
                  <p class="toc-title">Other pages</p>
                  <nav class="toc-nav">
                    {
                      relatedPosts.map((post) => (
                        <a class="toc-link" href={`/posts/${post.slug}/`}>
                          {post.data.title}
                        </a>
                      ))
                    }
                  </nav>
                </div>
              )
            }
          </div>
        </aside>
      )
    }
    <article class="article-shell">
      <header class="article-header">
        <div class="article-title-block">
          <div class="article-meta">
            {readingTime && <span>{readingTime} min read</span>}
            <span class="article-meta-spacer" aria-hidden="true"></span>
            <time datetime={pubDate.toISOString()}>
              {pubDate.toLocaleDateString('en-GB', {
                day: 'numeric',
                month: 'long',
                year: 'numeric'
              })}
            </time>
            {
              updatedDate && (
                <span>
                  Updated{' '}
                  {updatedDate.toLocaleDateString('en-GB', {
                    day: 'numeric',
                    month: 'long',
                    year: 'numeric'
                  })}
                </span>
              )
            }
          </div>
          <h1>{title}</h1>
          <p class="lede">{description}</p>
          {
            audio && (
              <div class="article-audio">
                <div class="article-audio-copy">
                  <p class="article-audio-label">{audio.title ?? 'Listen to this article'}</p>
                  <p class="article-audio-hint">Audio version</p>
                </div>
                <audio controls preload="none" src={audio.src}>
                  <a href={audio.src}>Download the audio version of this article</a>
                </audio>
                <p class="article-audio-credit">Audio generated by ElevenLabs.io</p>
              </div>
            )
          }
        </div>
      </header>
      <div class="article-body">
        <slot />
      </div>
      {
        relatedPosts.length > 0 && (
          <footer class="article-footer">
            <div class="article-footer-heading">
              <p class="eyebrow">Keep exploring the model</p>
            </div>
            <div class="related-grid">
              {
                relatedPosts.map((post) => (
                  <a class="related-card" href={`/posts/${post.slug}/`}>
                    <h3>{post.data.title}</h3>
                    <p>{post.data.description}</p>
                  </a>
                ))
              }
            </div>
          </footer>
        )
      }
    </article>
  </div>
  {
    tocHeadings.length > 0 && (
      <script is:inline>
        const tocRoot = document.querySelector('[data-toc-root]');
        const tocNav = document.querySelector('[data-toc-nav]');

        if (tocRoot) {
          const tocToggle = tocRoot.querySelector('[data-toc-toggle]');
          const tocPanel = tocRoot.querySelector('[data-toc-panel]');
          const tocBackdrop = tocRoot.querySelector('[data-toc-backdrop]');
          const tocClose = tocRoot.querySelector('[data-toc-close]');
          const mobileQuery = window.matchMedia('(max-width: 900px)');

          const setDrawerState = (isOpen) => {
            tocRoot.classList.toggle('is-open', isOpen);
            tocToggle?.setAttribute('aria-expanded', String(isOpen));

            if (tocBackdrop) {
              tocBackdrop.hidden = !isOpen;
            }
          };

          const closeDrawer = () => setDrawerState(false);

          tocToggle?.addEventListener('click', () => {
            const isOpen = !tocRoot.classList.contains('is-open');
            setDrawerState(isOpen);
          });

          tocClose?.addEventListener('click', closeDrawer);
          tocBackdrop?.addEventListener('click', closeDrawer);

          document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape') {
              closeDrawer();
            }
          });

          mobileQuery.addEventListener('change', (event) => {
            if (!event.matches) {
              closeDrawer();
            }
          });

          tocPanel?.querySelectorAll('a').forEach((link) => {
            link.addEventListener('click', () => {
              if (mobileQuery.matches) {
                closeDrawer();
              }
            });
          });
        }

        if (tocNav) {
          const tocLinks = Array.from(tocNav.querySelectorAll('a[href^="#"]'));
          const sections = tocLinks
            .map((link) => {
              const id = link.getAttribute('href')?.slice(1);

              if (!id) return null;

              const section = document.getElementById(id);
              return section ? { id, link, section } : null;
            })
            .filter(Boolean);

          const setActiveLink = (activeId) => {
            sections.forEach(({ id, link }) => {
              const isActive = id === activeId;
              link.classList.toggle('is-active', isActive);

              if (isActive) {
                link.setAttribute('aria-current', 'true');
              } else {
                link.removeAttribute('aria-current');
              }
            });
          };

          if (sections.length > 0) {
            const getActiveSection = () => {
              const offset = window.innerHeight * 0.22;
              let currentId = sections[0].id;

              for (const { id, section } of sections) {
                if (section.getBoundingClientRect().top - offset <= 0) {
                  currentId = id;
                } else {
                  break;
                }
              }

              return currentId;
            };

            const syncActiveSection = () => setActiveLink(getActiveSection());

            syncActiveSection();
            document.addEventListener('scroll', syncActiveSection, { passive: true });
            window.addEventListener('resize', syncActiveSection);
          }
        }
      </script>
    )
  }
</BaseLayout>
