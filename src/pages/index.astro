---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featuredPost = posts.find((post) => post.data.featured) ?? posts[0];
const supportingPosts = posts.filter((post) => post.id !== featuredPost?.id);
---

<BaseLayout>
  <div class="home-layout">
    <aside class="home-sidebar" aria-label="Homepage introduction">
      <h1>Essays on clarity, systems and AI-native companies.</h1>
      <p class="hero-copy">
        A growing body of work around the Clarity thesis, with essays that explain the model and
        examples that show how it changes real operating decisions.
      </p>
      <div class="home-sidebar-note">
        <p>
          Begin with the core thesis, then move through the supporting essays as the system gets
          more concrete.
        </p>
      </div>
    </aside>

    <section class="home-main">
      {
        featuredPost && (
          <a class="home-feature" href={`/posts/${featuredPost.slug}/`}>
            <div class="home-feature-copy">
              <h2>{featuredPost.data.title}</h2>
              <p>{featuredPost.data.description}</p>
            </div>
            <time datetime={featuredPost.data.pubDate.toISOString()}>
              {featuredPost.data.pubDate.toLocaleDateString('en-GB', {
                day: 'numeric',
                month: 'short',
                year: 'numeric'
              })}
            </time>
          </a>
        )
      }

      <div class="post-list">
        {
          supportingPosts.map((post) => (
            <a class="post-card" href={`/posts/${post.slug}/`}>
              <div>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
              </div>
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('en-GB', {
                  day: 'numeric',
                  month: 'short',
                  year: 'numeric'
                })}
              </time>
            </a>
          ))
        }
      </div>
      {
        supportingPosts.length === 0 && (
          <p class="empty-state">
            The collection currently starts with one foundation essay. Additional posts can be
            added under <code>src/content/posts/</code>.
          </p>
        )
      }
    </section>
  </div>
</BaseLayout>
