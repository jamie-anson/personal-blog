---
import { getCollection, render } from 'astro:content';
import ExperimentalWrappedFigure from '../../components/ExperimentalWrappedFigure.astro';
import PostLayout from '../../layouts/PostLayout.astro';

const EXPERIMENTAL_WRAPPED_FIGURE_POSTS = new Set(['clarity']);
const CLARITY_INTRO_PARAGRAPHS = [
  'Anyone can do anything now.',
  'AI has made execution fast and accessible.',
  'A single builder can now design, build, market and analyse in a single day. Not because they are exceptional, but because the tools extend what anyone can do.',
  'The constraint is no longer skill. The constraint is clarity.'
];

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: {
      post,
      relatedPosts: posts.filter((candidate) => candidate.id !== post.id).slice(0, 2)
    }
  }));
}

const { post, relatedPosts } = Astro.props;
const { Content, headings } = await render(post);
const readingTime = Math.max(1, Math.round(post.body.split(/\s+/).filter(Boolean).length / 220));
const isWrappedFigurePilot = EXPERIMENTAL_WRAPPED_FIGURE_POSTS.has(post.slug);
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  readingTime={readingTime}
  relatedPosts={relatedPosts}
  headings={headings}
>
  {
    isWrappedFigurePilot && (
      <ExperimentalWrappedFigure
        imageSrc="/clarity-figure.svg"
        imageAlt="A structured diagram showing belief, seam, spec, and section arranged as a vertical operating loop."
        caption="A simple operating loop: belief becomes seam, seam drives spec, spec shapes section."
        paragraphs={CLARITY_INTRO_PARAGRAPHS}
      />
    )
  }
  <Content />
</PostLayout>
